# Copy to .env for local dev (optional — without these, local SQLite is used)
# SECRET_KEY=dev-secret-change-in-production
# ADMIN_PASSWORD=Iconic

# Turso (production on Render) — get from https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-token-here

# Local SQLite path when Turso is not configured (default: data/food_bank.db)
# DATABASE_PATH=data/food_bank.db
